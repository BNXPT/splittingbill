# ===== ตอนรันในเครื่อง: ไม่ต้องตั้งอะไรเลย (จะใช้ SQLite ไฟล์ local อัตโนมัติ) =====

# ===== ตอน deploy บน Render: ตั้งค่าเหล่านี้ =====
# ลิงก์ฐานข้อมูล PostgreSQL (Render จะใส่ให้อัตโนมัติถ้าผูก database)
# มีค่านี้เมื่อไหร่ ระบบจะสลับไปใช้ Postgres ทันที
DATABASE_URL=postgres://user:password@host:5432/dbname

# ลิงก์ frontend (Vercel) เพื่ออนุญาต CORS — ใส่หลายอันคั่นด้วย comma ได้
CORS_ORIGIN=https://your-frontend.vercel.app

# port (Render กำหนดให้เอง ไม่ต้องตั้ง)
# PORT=3001
