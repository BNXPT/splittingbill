# ค่าตั้งต้นสำหรับ docker compose (Postgres + PgAdmin)
# คัดลอกเป็น .env ถ้าอยากเปลี่ยนค่า — ถ้าไม่มี .env จะใช้ค่า default เหล่านี้อยู่แล้ว
POSTGRES_USER=billsplit
POSTGRES_PASSWORD=billsplit
POSTGRES_DB=billsplit

# บัญชีเข้า PgAdmin ที่ http://localhost:5050
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
